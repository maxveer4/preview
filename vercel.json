{
  "functions": {
    "api/create-website.js": { "maxDuration": 60 }
  },
  "rewrites": [
    { "source": "/editor",       "destination": "/public/editor/index.html" },
    { "source": "/editor/",      "destination": "/public/editor/index.html" },
    { "source": "/(.*)",         "destination": "/public/$1" }
  ]
}
